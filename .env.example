# Helius API key (backend only — never exposed to the frontend).
# The app still starts without one; /api/rpc/status will report "not configured".
HELIUS_API_KEY=

# Solana cluster: mainnet-beta or devnet
SOLANA_CLUSTER=mainnet-beta

# SQLite database (relative paths resolve against the prisma/ directory)
DATABASE_URL=file:./dev.db

# Backend port
API_PORT=3001

# Allowed CORS origin for the web dashboard
WEB_ORIGIN=http://localhost:5173

# Frontend: base URL of the API (safe to expose — contains no secrets)
VITE_API_BASE_URL=http://localhost:3001
