# Helius API key (backend only — never exposed to the frontend).
# The app still starts without one; /api/rpc/status will report "not configured".
HELIUS_API_KEY=

# Solana cluster: mainnet-beta or devnet
SOLANA_CLUSTER=mainnet-beta

# SQLite database (relative paths resolve against the prisma/ directory)
DATABASE_URL=file:./dev.db

# Backend port
API_PORT=3001

# Allowed CORS origin for the web dashboard
WEB_ORIGIN=http://localhost:5173

# Frontend: base URL of the API (safe to expose — contains no secrets)
VITE_API_BASE_URL=http://localhost:3001

# Market-data provider for current token snapshots (Phase 1D-B1).
# "dexscreener" (default) uses DexScreener's public API — no API key required.
# "none" disables market lookups. Backend-only; provider credentials, if any
# provider ever needs one, must NEVER use a VITE_ variable.
MARKET_DATA_PROVIDER=dexscreener
