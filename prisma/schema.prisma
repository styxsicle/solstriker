// Memecoin Lab — Phase 1A schema.
// SQLite does not support Prisma enums or string lists, so:
//  - Token.stage is a String validated at the app layer
//    (UNCLASSIFIED | FINAL_STRETCH | MIGRATED).
//  - TrackedWallet.groupsJson stores the full group list as a JSON array;
//    TrackedWallet.group holds the primary (first) group for fast filtering.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TrackedWallet {
  id         String   @id @default(cuid())
  address    String   @unique
  label      String?
  group      String?
  groupsJson String?
  emoji      String?
  notes      String?
  metaJson   String?
  enabled    Boolean  @default(true)
  source     String   @default("manual")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events    WalletEvent[]
  syncState WalletSyncState?
  reconstructedPositions WalletPosition[]
  behaviorProfiles WalletBehaviorProfile[]
  qualityMetricSets WalletQualityMetricSet[]
  cohortMemberships FocusTraderCohortMember[]
  strategyFingerprints WalletStrategyFingerprint[]

  @@index([group])
  @@index([enabled])
}

model Token {
  id           String   @id @default(cuid())
  mintAddress  String   @unique
  name         String?
  symbol       String?
  stage        String   @default("UNCLASSIFIED")
  source       String   @default("dev-seed")
  discoveredAt DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events          WalletEvent[]
  marketSnapshots TokenMarketSnapshot[]
  candles         TokenMarketCandle[]
  entryOutcomes   WalletEntryOutcome[]
  walletPositions WalletPosition[]

  @@index([stage])
}

// One manual market-data refresh request (auditable batch).
// status: RUNNING | COMPLETED | PARTIAL | FAILED
model TokenMarketRefreshRun {
  id                    String    @id @default(cuid())
  provider              String
  status                String    @default("RUNNING")
  startedAt             DateTime  @default(now())
  completedAt           DateTime?
  requestedCount        Int       @default(0)
  processedCount        Int       @default(0)
  completeCount         Int       @default(0)
  partialCount          Int       @default(0)
  notFoundCount         Int       @default(0)
  errorCount            Int       @default(0)
  snapshotCount         Int       @default(0)
  sanitizedErrorSummary String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  snapshots TokenMarketSnapshot[]

  @@index([startedAt])
}

// One market observation of one token within one refresh run.
// Financial values are stored as exact decimal STRINGS: SQLite (this project's
// datastore) has no Decimal type, and strings preserve the provider's exact
// numbers without float loss. Unknown values are NULL — never zero.
// status: COMPLETE | PARTIAL | NOT_FOUND | ERROR
// confidence: HIGH | MEDIUM | LOW | UNKNOWN
model TokenMarketSnapshot {
  id                 String   @id @default(cuid())
  tokenId            String
  refreshRunId       String
  observedAt         DateTime // provider observation time (= fetchedAt for providers without one)
  fetchedAt          DateTime @default(now())
  priceUsd           String?
  priceSol           String? // only when the selected pair is SOL-quoted (priceNative)
  marketCapUsd       String? // circulating estimate — NEVER substituted with FDV
  fdvUsd             String? // fully-diluted estimate — kept strictly separate
  liquidityUsd       String?
  volume5mUsd        String?
  volume1hUsd        String?
  volume6hUsd        String?
  volume24hUsd       String?
  buys5m             Int?
  sells5m            Int?
  buys1h             Int?
  sells1h            Int?
  buys6h             Int?
  sells6h            Int?
  buys24h            Int?
  sells24h           Int?
  priceChange5mPct   String?
  priceChange1hPct   String?
  priceChange6hPct   String?
  priceChange24hPct  String?
  pairAddress        String?
  dex                String?
  baseMint           String?
  quoteMint          String?
  tokenName          String?
  tokenSymbol        String?
  source             String
  status             String
  confidence         String   @default("UNKNOWN")
  selectionReason    String?
  sanitizedErrorCode String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  token      Token                 @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  refreshRun TokenMarketRefreshRun @relation(fields: [refreshRunId], references: [id], onDelete: Cascade)

  @@unique([refreshRunId, tokenId]) // one auditable result per token per run
  @@index([tokenId, observedAt])
  @@index([tokenId, fetchedAt])
  @@index([refreshRunId])
  @@index([source])
  @@index([status])
  @@index([observedAt])
}

// One normalized buy/sell/transfer leg of a transaction, from the perspective
// of a tracked wallet. eventType is a String (SQLite lacks enums) validated at
// the app layer: BUY | SELL | TOKEN_TRANSFER_IN | TOKEN_TRANSFER_OUT.
// dedupeKey = walletId:signature:eventType:mint — makes re-syncs idempotent.
model WalletEvent {
  id          String    @id @default(cuid())
  dedupeKey   String    @unique
  walletId    String
  tokenId     String?
  signature   String
  eventType   String
  tokenAmount Float?
  quoteMint   String? // "SOL" or a stablecoin mint; exact swap leg only (never invented)
  quoteAmount Float?
  source      String? // originating app / router as reported by the provider (e.g. JUPITER, AXIOM)
  slot        Int?
  blockTime   DateTime?
  createdAt   DateTime  @default(now())

  // --- Phase 1C reliable swap decoding (all additive, nullable) ---
  venue           String? // actual execution venue(s) when decoded, e.g. PUMP_AMM, RAYDIUM
  confidence      String? // CONFIRMED | LIKELY | UNKNOWN
  explanation     String? // human-readable reason for the classification
  swapInMint      String? // exact decoded swap input leg
  swapInAmount    Float?
  swapOutMint     String? // exact decoded swap output leg
  swapOutAmount   Float?
  walletSolChange Float? // exact total wallet SOL balance change (signed)
  networkFeeSol   Float?
  priorityFeeSol  Float? // identifiable portion above base fee (1-signature assumption)
  platformFeeSol  Float?
  tipSol          Float?
  rentSol         Float? // token-account creation / rent-exempt deposits paid
  unrelatedSolIn  Float?
  unrelatedSolOut Float?
  unattributedSol Float? // reconciliation residue (signed)
  decoderVersion  Int     @default(1) // 1 = legacy heuristic, 2 = Phase 1C decoder

  wallet   TrackedWallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  token    Token?               @relation(fields: [tokenId], references: [id])
  outcomes WalletEntryOutcome[]

  @@index([walletId, blockTime])
  @@index([tokenId])
  @@index([eventType])
  @@index([signature])
}

// Per-wallet sync bookkeeping.
// oldestSignature = backfill cursor (fetching backwards in history);
// newestSignature = incremental cursor (stop when reached on later syncs).
model WalletSyncState {
  id                String    @id @default(cuid())
  walletId          String    @unique
  status            String    @default("idle") // idle | syncing | error
  backfillComplete  Boolean   @default(false)
  oldestSignature   String?
  newestSignature   String?
  lastSyncAt        DateTime?
  lastError         String? // sanitized error code only — never URLs or keys
  totalTransactions Int       @default(0)
  totalEvents       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  wallet TrackedWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Phase 1D-B2 — historical OHLCV candles and post-wallet-entry outcomes.
// All financial values are exact decimal STRINGS (SQLite has no Decimal type);
// unknown values are NULL, never zero. Timestamps are stored UTC.
// ---------------------------------------------------------------------------

// One manual, bounded historical-candle backfill request (auditable batch).
// status: RUNNING | COMPLETED | PARTIAL | FAILED
model HistoricalMarketBackfillRun {
  id                    String    @id @default(cuid())
  provider              String
  status                String    @default("RUNNING")
  startedAt             DateTime  @default(now())
  completedAt           DateTime?
  requestedTokenCount   Int       @default(0)
  processedTokenCount   Int       @default(0)
  requestedInterval     String
  requestedStart        DateTime
  requestedEnd          DateTime
  candlesInserted       Int       @default(0)
  candlesUpdated        Int       @default(0)
  duplicatesPrevented   Int       @default(0)
  gapCount              Int       @default(0)
  completeCount         Int       @default(0)
  partialCount          Int       @default(0)
  notFoundCount         Int       @default(0)
  errorCount            Int       @default(0)
  sanitizedErrorSummary String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  candles TokenMarketCandle[]

  @@index([startedAt])
}

// One OHLCV candle for one pair at one interval. openTime is the candle's
// start (UTC); closeTime = openTime + interval duration. Gaps are NOT stored
// (no manufactured/zero candles). Uniqueness prevents duplicates on re-fetch;
// an existing candle may be updated if the provider returns corrected values.
model TokenMarketCandle {
  id            String   @id @default(cuid())
  tokenId       String
  pairAddress   String
  interval      String // e.g. "1m", "5m", "15m", "1h"
  openTime      DateTime
  closeTime     DateTime
  open          String
  high          String
  low           String
  close         String
  volumeUsd     String? // null when the provider did not report volume
  source        String
  fetchedAt     DateTime @default(now())
  backfillRunId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  token       Token                       @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  backfillRun HistoricalMarketBackfillRun @relation(fields: [backfillRunId], references: [id], onDelete: Cascade)

  @@unique([tokenId, pairAddress, interval, openTime, source])
  @@index([tokenId, openTime])
  @@index([pairAddress, openTime])
  @@index([interval, openTime])
  @@index([backfillRunId])
  @@index([source])
  @@index([openTime])
}

// Historical market outcome of one BUY WalletEvent, derived only from stored
// candles AFTER the event time (no look-ahead). Never modifies the WalletEvent.
// entryPriceMethod: EXACT_SNAPSHOT | CANDLE_OPEN | CANDLE_CLOSE | CANDLE_INTERPOLATED | UNAVAILABLE
// status: COMPLETE | PARTIAL | UNAVAILABLE | ERROR
// confidence: HIGH | MEDIUM | LOW | UNKNOWN
model WalletEntryOutcome {
  id                  String    @id @default(cuid())
  walletEventId       String
  tokenId             String
  pairAddress         String?
  entryTime           DateTime
  entryPriceUsd       String?
  entryPriceMethod    String
  entryCandleTime     DateTime?
  entryDelaySeconds   Int?
  price1mUsd          String?
  price5mUsd          String?
  price15mUsd         String?
  price30mUsd         String?
  price1hUsd          String?
  price4hUsd          String?
  price24hUsd         String?
  return1mPct         String?
  return5mPct         String?
  return15mPct        String?
  return30mPct        String?
  return1hPct         String?
  return4hPct         String?
  return24hPct        String?
  maxPrice1hUsd       String?
  minPrice1hUsd       String?
  maxReturn1hPct      String?
  maxDrawdown1hPct    String?
  timeToMax1hSeconds  Int?
  maxPrice24hUsd      String?
  minPrice24hUsd      String?
  maxReturn24hPct     String?
  maxDrawdown24hPct   String?
  timeToMax24hSeconds Int?
  status              String
  confidence          String    @default("UNKNOWN")
  coverageStart       DateTime?
  coverageEnd         DateTime?
  missingWindowCount  Int       @default(0)
  calculationVersion  Int       @default(1)
  calculatedAt        DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  walletEvent WalletEvent @relation(fields: [walletEventId], references: [id], onDelete: Cascade)
  token       Token       @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([walletEventId, calculationVersion])
  @@index([tokenId])
  @@index([status])
  @@index([calculatedAt])
}

// Phase 2A — one auditable, explicit, bounded wallet reconstruction request.
model WalletPositionReconstructionRun {
  id                    String    @id @default(cuid())
  calculationVersion    Int       @default(1)
  method                String    @default("FIFO")
  status                String    @default("RUNNING")
  startedAt             DateTime  @default(now())
  completedAt           DateTime?
  requestedWalletCount  Int       @default(0)
  processedWalletCount  Int       @default(0)
  eventCount            Int       @default(0)
  includedEventCount    Int       @default(0)
  excludedEventCount    Int       @default(0)
  positionCount         Int       @default(0)
  matchCount            Int       @default(0)
  profileCount          Int       @default(0)
  warningCount          Int       @default(0)
  errorCount            Int       @default(0)
  sanitizedErrorSummary String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  positions WalletPosition[]
  profiles  WalletBehaviorProfile[]
  qualityMetricSets WalletQualityMetricSet[]

  @@index([startedAt])
  @@index([status])
}

model WalletPosition {
  id                         String   @id @default(cuid())
  reconstructionRunId        String
  trackedWalletId            String
  tokenId                    String
  cycleNumber                Int
  status                     String
  confidence                 String
  openedAt                   DateTime?
  closedAt                   DateTime?
  firstBuyEventId            String?
  lastEventAt                DateTime?
  quoteAsset                 String   @default("SOL")
  totalBoughtTokenAmount     String?
  totalSoldTokenAmount       String?
  openTokenAmount            String?
  knownCostBasisSol          String?
  knownProceedsSol           String?
  allocatedKnownFeesSol      String?
  rawRealizedPnlSol          String?
  knownAllInRealizedPnlSol   String?
  rawRealizedRoiPct          String?
  knownAllInRealizedRoiPct   String?
  estimatedCurrentValueSol   String?
  estimatedCurrentValueUsd   String?
  estimatedUnrealizedPnlSol  String?
  estimatedUnrealizedRoiPct  String?
  valuationSnapshotId        String?
  valuationObservedAt        DateTime?
  valuationFreshness         String?
  valuationStatus            String?
  holdingDurationSeconds     Int?
  transferInAmount           String?
  transferOutAmount          String?
  unmatchedSellAmount        String?
  unknownBasisAmount         String?
  includedEventCount         Int      @default(0)
  excludedEventCount         Int      @default(0)
  includedEventIdsJson       String   @default("[]")
  exclusionReasonsJson       String   @default("[]")
  decoderVersionsJson        String   @default("[]")
  warningCodes               String   @default("[]")
  calculationVersion         Int      @default(1)
  calculatedAt               DateTime @default(now())
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  reconstructionRun WalletPositionReconstructionRun @relation(fields: [reconstructionRunId], references: [id], onDelete: Cascade)
  trackedWallet     TrackedWallet @relation(fields: [trackedWalletId], references: [id])
  token             Token @relation(fields: [tokenId], references: [id])
  matches           WalletTradeMatch[]

  @@unique([reconstructionRunId, trackedWalletId, tokenId, cycleNumber])
  @@index([trackedWalletId])
  @@index([tokenId])
  @@index([status])
  @@index([reconstructionRunId])
  @@index([openedAt])
  @@index([closedAt])
  @@index([calculationVersion])
}

model WalletTradeMatch {
  id                         String   @id @default(cuid())
  positionId                 String
  buyEventId                 String
  sellEventId                String
  sequence                   Int
  matchedTokenAmount         String
  allocatedBuyCostSol        String?
  allocatedBuyFeesSol        String?
  allocatedSellProceedsSol   String?
  allocatedSellFeesSol       String?
  rawRealizedPnlSol          String?
  knownAllInRealizedPnlSol   String?
  rawRealizedRoiPct          String?
  knownAllInRealizedRoiPct   String?
  holdingDurationSeconds     Int?
  confidence                 String
  warningCodes               String   @default("[]")
  calculationVersion         Int      @default(1)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  position WalletPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([positionId, buyEventId, sellEventId, sequence, calculationVersion])
  @@index([buyEventId])
  @@index([sellEventId])
  @@index([calculationVersion])
}

model WalletBehaviorProfile {
  id                              String   @id @default(cuid())
  reconstructionRunId             String
  trackedWalletId                 String
  calculationVersion              Int      @default(1)
  status                          String
  confidence                      String
  eligibleBuyCount                Int      @default(0)
  eligibleSellCount               Int      @default(0)
  closedPositionCount             Int      @default(0)
  openPositionCount               Int      @default(0)
  partialPositionCount            Int      @default(0)
  unmatchedSellCount              Int      @default(0)
  transferAffectedPositionCount   Int      @default(0)
  knownPositionSizeMedianSol      String?
  knownPositionSizeMeanSol        String?
  knownPositionSizeP25Sol         String?
  knownPositionSizeP75Sol         String?
  knownPositionSizeMinSol         String?
  knownPositionSizeMaxSol         String?
  closedHoldingMedianSeconds      String?
  closedHoldingMeanSeconds        String?
  observedMaxConcurrentPositions  Int      @default(0)
  knownFeeBurdenMedianPct         String?
  completeHistory                 Boolean  @default(false)
  warningCodes                    String   @default("[]")
  calculatedAt                    DateTime @default(now())
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  reconstructionRun WalletPositionReconstructionRun @relation(fields: [reconstructionRunId], references: [id], onDelete: Cascade)
  trackedWallet TrackedWallet @relation(fields: [trackedWalletId], references: [id])

  @@unique([reconstructionRunId, trackedWalletId, calculationVersion])
  @@index([trackedWalletId])
  @@index([reconstructionRunId])
  @@index([status])
  @@index([calculationVersion])
}

// Phase 2B — auditable, bounded descriptive quality-evidence analysis.
model WalletQualityAnalysisRun {
  id                    String    @id @default(cuid())
  calculationVersion    Int       @default(1)
  status                String    @default("RUNNING")
  startedAt             DateTime  @default(now())
  completedAt           DateTime?
  requestedWalletCount  Int       @default(0)
  processedWalletCount  Int       @default(0)
  eligiblePositionCount Int       @default(0)
  excludedPositionCount Int       @default(0)
  metricSetCount        Int       @default(0)
  categorySetCount      Int       @default(0)
  timeWindowSetCount    Int       @default(0)
  warningCount          Int       @default(0)
  errorCount            Int       @default(0)
  sanitizedErrorSummary String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  metricSets WalletQualityMetricSet[]

  @@index([status])
  @@index([startedAt])
  @@index([calculationVersion])
}

model WalletQualityMetricSet {
  id                         String   @id @default(cuid())
  analysisRunId              String
  reconstructionRunId        String
  trackedWalletId            String
  calculationVersion         Int      @default(1)
  status                     String
  confidence                 String
  sampleSizeTier             String
  totalPositionCount         Int      @default(0)
  eligibleClosedCount        Int      @default(0)
  eligibleOpenCount          Int      @default(0)
  excludedCount              Int      @default(0)
  highConfidenceCount        Int      @default(0)
  lowerConfidenceCount       Int      @default(0)
  positiveRawCount           Int      @default(0)
  negativeRawCount           Int      @default(0)
  flatRawCount               Int      @default(0)
  positiveAllInCount         Int      @default(0)
  negativeAllInCount         Int      @default(0)
  rawPositiveRatePct         String?
  allInPositiveRatePct       String?
  medianRawPnlSol            String?
  meanRawPnlSol              String?
  p25RawPnlSol               String?
  p75RawPnlSol               String?
  minRawPnlSol               String?
  maxRawPnlSol               String?
  medianAllInPnlSol          String?
  meanAllInPnlSol            String?
  medianRawRoiPct            String?
  meanRawRoiPct              String?
  p25RawRoiPct               String?
  p75RawRoiPct               String?
  medianAllInRoiPct          String?
  meanAllInRoiPct            String?
  grossGainSol               String?
  grossLossSol               String?
  profitFactor               String?
  largestGainContributionPct String?
  largestLossContributionPct String?
  medianHoldingSeconds       String?
  meanHoldingSeconds         String?
  p25HoldingSeconds          String?
  p75HoldingSeconds          String?
  medianPositionSizeSol      String?
  meanPositionSizeSol        String?
  p25PositionSizeSol         String?
  p75PositionSizeSol         String?
  observedDistinctTokenCount Int      @default(0)
  transferAffectedCount      Int      @default(0)
  unmatchedSellCount         Int      @default(0)
  completeHistory            Boolean  @default(false)
  eligibleCoveragePct        String?
  knownFeeCoveragePct        String?
  outcomeCoveragePct         String?
  complete1hOutcomePct       String?
  complete24hOutcomePct      String?
  consistencyJson            String   @default("{}")
  holdingBucketsJson         String   @default("{}")
  outcomeMetricsJson         String   @default("{}")
  warningCodes               String   @default("[]")
  calculatedAt               DateTime @default(now())
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  analysisRun       WalletQualityAnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  reconstructionRun WalletPositionReconstructionRun @relation(fields: [reconstructionRunId], references: [id])
  trackedWallet     TrackedWallet @relation(fields: [trackedWalletId], references: [id])
  categories        WalletCategoryMetric[]
  timeWindows       WalletTimeWindowMetric[]

  @@unique([analysisRunId, trackedWalletId, calculationVersion])
  @@index([trackedWalletId])
  @@index([analysisRunId])
  @@index([reconstructionRunId])
  @@index([sampleSizeTier])
  @@index([status])
  @@index([calculationVersion])
  @@index([calculatedAt])
}

model WalletCategoryMetric {
  id                    String   @id @default(cuid())
  metricSetId           String
  categoryType          String
  categoryValue         String
  totalSampleCount      Int      @default(0)
  eligibleSampleCount   Int      @default(0)
  excludedSampleCount   Int      @default(0)
  confidence            String
  positiveRawCount      Int      @default(0)
  negativeRawCount      Int      @default(0)
  rawPositiveRatePct    String?
  medianRawPnlSol       String?
  medianRawRoiPct       String?
  medianAllInRoiPct     String?
  medianHoldingSeconds  String?
  medianPositionSizeSol String?
  warningCodes          String   @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  metricSet WalletQualityMetricSet @relation(fields: [metricSetId], references: [id], onDelete: Cascade)

  @@unique([metricSetId, categoryType, categoryValue])
  @@index([categoryType, categoryValue])
  @@index([confidence])
}

model WalletTimeWindowMetric {
  id                    String    @id @default(cuid())
  metricSetId           String
  windowType            String
  windowStart           DateTime?
  windowEnd             DateTime?
  sampleCount           Int       @default(0)
  eligibleSampleCount   Int       @default(0)
  confidence            String
  positiveRawRatePct    String?
  medianRawPnlSol       String?
  medianRawRoiPct       String?
  medianAllInRoiPct     String?
  medianHoldingSeconds  String?
  medianPositionSizeSol String?
  warningCodes          String    @default("[]")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  metricSet WalletQualityMetricSet @relation(fields: [metricSetId], references: [id], onDelete: Cascade)

  @@unique([metricSetId, windowType])
  @@index([windowType])
  @@index([windowStart, windowEnd])
  @@index([confidence])
}

// ---------------------------------------------------------------------------
// Phase 2C-A — Focus Trader Strategy Lab.
//
// A focus cohort is a USER-SELECTED research grouping of public wallets. It is
// an organizational convenience only: membership never asserts, implies, or
// establishes that the wallets share an owner, an operator, or any coordination.
// Similar labels, funding transfers, shared tokens and similar timing are all
// explicitly insufficient to establish ownership.
//
// Deleting a cohort removes only the cohort and its membership rows. Tracked
// wallets, events, positions, quality records and fingerprints are never
// touched by cohort deletion (the wallet relation intentionally has no cascade).
// ---------------------------------------------------------------------------
model FocusTraderCohort {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members FocusTraderCohortMember[]

  @@index([name])
  @@index([createdAt])
}

// role: PRIMARY (exactly one per cohort) | COMPARISON (zero to nine per cohort).
// displayOrder preserves the user's own ordering — never a ranking.
model FocusTraderCohortMember {
  id              String   @id @default(cuid())
  cohortId        String
  trackedWalletId String
  role            String   @default("COMPARISON")
  displayOrder    Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cohort        FocusTraderCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  trackedWallet TrackedWallet     @relation(fields: [trackedWalletId], references: [id])

  @@unique([cohortId, trackedWalletId]) // a wallet appears at most once per cohort
  @@index([cohortId, displayOrder])
  @@index([trackedWalletId])
  @@index([role])
}

// One manual, bounded, auditable strategy-fingerprint calculation request.
// status: RUNNING | COMPLETED | PARTIAL | FAILED
model WalletStrategyFingerprintRun {
  id                    String    @id @default(cuid())
  calculationVersion    Int       @default(1)
  status                String    @default("RUNNING")
  startedAt             DateTime  @default(now())
  completedAt           DateTime?
  requestedWalletCount  Int       @default(0)
  processedWalletCount  Int       @default(0)
  fingerprintCount      Int       @default(0)
  patternCount          Int       @default(0)
  eligibleCycleCount    Int       @default(0)
  excludedCycleCount    Int       @default(0)
  warningCount          Int       @default(0)
  errorCount            Int       @default(0)
  sanitizedErrorSummary String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  fingerprints WalletStrategyFingerprint[]

  @@index([status])
  @@index([startedAt])
  @@index([calculationVersion])
}

// Descriptive structure of how one wallet's observed position cycles were
// entered, sized, managed and exited. Every value is derived only from the
// wallet's LATEST COMPLETED reconstruction (runs are never combined).
// All financial values are exact decimal STRINGS; unknown values are NULL.
// Nothing here measures profitability, skill, ownership or copyability.
model WalletStrategyFingerprint {
  id                                String   @id @default(cuid())
  runId                             String
  trackedWalletId                   String
  reconstructionRunId               String
  qualityMetricSetId                String?
  calculationVersion                Int      @default(1)
  status                            String
  confidence                        String
  // --- sample ---
  eligibleCycleCount                Int      @default(0)
  excludedCycleCount                Int      @default(0)
  eligibleBuyCount                  Int      @default(0)
  eligibleSellCount                 Int      @default(0)
  // --- entry structure ---
  medianBuysPerCycle                String?
  meanBuysPerCycle                  String?
  p25BuysPerCycle                   String?
  p75BuysPerCycle                   String?
  singleBuyCycleCount               Int      @default(0)
  twoBuyCycleCount                  Int      @default(0)
  multiBuyCycleCount                Int      @default(0)
  medianFirstToSecondBuySeconds     String?
  medianLaterBuyGapSeconds          String?
  medianFirstBuySol                 String?
  medianCycleCostSol                String?
  p75CycleCostSol                   String?
  medianFirstBuySharePct            String?
  medianLargestBuySharePct          String?
  largestBuyFirstCycleCount         Int      @default(0)
  increasingSizeCycleCount          Int      @default(0)
  // --- exit structure ---
  cyclesWithSellCount               Int      @default(0)
  medianSellsPerCycle               String?
  singleSellCycleCount              Int      @default(0)
  twoSellCycleCount                 Int      @default(0)
  multiSellCycleCount               Int      @default(0)
  medianFirstBuyToFirstSellSeconds  String?
  medianLastBuyToFirstSellSeconds   String?
  medianFirstSellInventoryPct       String?
  medianLargestSellInventoryPct     String?
  medianRemainingAfterFirstSellPct  String?
  medianFirstSellToFinalSellSeconds String?
  partialFirstExitCycleCount        Int      @default(0)
  fullyClosedCycleCount             Int      @default(0)
  openCycleCount                    Int      @default(0)
  // --- evidence limits ---
  transferAffectedCycleCount        Int      @default(0)
  unmatchedSellCount                Int      @default(0)
  unknownBasisCycleCount            Int      @default(0)
  missingFeeCycleCount              Int      @default(0)
  eligibleCoveragePct               String?
  feeCoveragePct                    String?
  completeHistory                   Boolean  @default(false)
  // --- token repetition ---
  distinctTokenCount                Int      @default(0)
  repeatedTokenCount                Int      @default(0)
  repeatedTokenCycleCount           Int      @default(0)
  maxCyclesPerToken                 Int      @default(0)
  medianSecondsBetweenTokenCycles   String?
  // --- fees ---
  medianFeePerBuySol                String?
  medianFeePerSellSol               String?
  medianFeePerCycleSol              String?
  medianFeeBurdenPct                String?
  p75FeeBurdenPct                   String?
  feeBurdenOver1PctCount            Int      @default(0)
  feeBurdenOver2PctCount            Int      @default(0)
  feeBurdenOver5PctCount            Int      @default(0)
  feeBurdenOver10PctCount           Int      @default(0)
  medianLegsPerCycle                String?
  // --- concurrency ---
  observedMaxConcurrentPositions    Int      @default(0)
  medianConcurrentPositions         String?
  // --- descriptors ---
  descriptorCodes                   String   @default("[]")
  descriptorEvidenceJson            String   @default("[]")
  warningCodes                      String   @default("[]")
  calculatedAt                      DateTime @default(now())
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  run               WalletStrategyFingerprintRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  trackedWallet     TrackedWallet                  @relation(fields: [trackedWalletId], references: [id])
  patterns          WalletStrategyPatternMetric[]

  @@unique([runId, trackedWalletId, calculationVersion]) // idempotent per run
  @@index([trackedWalletId])
  @@index([runId])
  @@index([reconstructionRunId])
  @@index([qualityMetricSetId])
  @@index([status])
  @@index([confidence])
  @@index([calculationVersion])
  @@index([calculatedAt])
}

// One factual distribution row of a fingerprint.
// patternType: ENTRY_COUNT | EXIT_COUNT | ENTRY_TIMING | EXIT_TIMING |
//              HOLDING_DURATION | VENUE | ROUTER | FEE_BURDEN |
//              TOKEN_REPETITION | POSITION_SIZE | COMPLETENESS
// Rows are never ranked — ordering is by pattern type and stable value order.
model WalletStrategyPatternMetric {
  id                    String   @id @default(cuid())
  fingerprintId         String
  patternType           String
  patternValue          String
  sortOrder             Int      @default(0)
  totalCount            Int      @default(0)
  eligibleCount         Int      @default(0)
  excludedCount         Int      @default(0)
  percentage            String?
  medianSizeSol         String?
  medianDurationSeconds String?
  medianRawResultSol    String?
  confidence            String
  warningCodes          String   @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  fingerprint WalletStrategyFingerprint @relation(fields: [fingerprintId], references: [id], onDelete: Cascade)

  @@unique([fingerprintId, patternType, patternValue])
  @@index([fingerprintId, patternType, sortOrder])
  @@index([patternType])
  @@index([confidence])
}
